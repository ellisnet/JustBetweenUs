<Application x:Class="JustBetweenUs.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Open Sans font - the Fonts.xaml merge does not work on Skia targets;
             instead, reference the .ttf file directly via the OpenSansFont resource key below -->
        <!--<ResourceDictionary Source="ms-appx:///CodeBrix.Platform.Fonts.OpenSans/Fonts/OpenSans.ttf" />-->
      </ResourceDictionary.MergedDictionaries>
        <FontFamily x:Key="OpenSansFont">ms-appx:///CodeBrix.Platform.Fonts.OpenSans/Fonts/OpenSans.ttf</FontFamily>
      </ResourceDictionary>
  </Application.Resources>

</Application>
